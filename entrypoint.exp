#!/usr/bin/expect -f

set config "$env(HOME)/.claude.json"
set workdir [exec pwd]

# Pre-trust working directory
if {[file exists $config]} {
    catch {exec node -e "
const fs = require('fs');
const c = JSON.parse(fs.readFileSync('$config','utf8'));
if (!c.projects) c.projects={};
if (!c.projects\['$workdir'\]) c.projects\['$workdir'\]={};
c.projects\['$workdir'\].hasTrustDialogAccepted=true;
fs.writeFileSync('$config',JSON.stringify(c));
"}
}

set timeout -1
spawn claude --dangerously-load-development-channels server:line --dangerously-skip-permissions

# Wait for Claude to render, then press Enter to confirm any dialogs
# (development channels warning + any other first-time prompts)
sleep 4
send "\r"
sleep 2
send "\r"

# Hand off — stay alive as long as claude runs
interact
